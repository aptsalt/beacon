# Copy this file to ".env" and paste your Cohere trial key.
# Get one free at https://dashboard.cohere.com  ->  API Keys  ->  Trial key
COHERE_API_KEY=

# Models (override if Cohere updates names). Defaults target current flagship tiers.
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-v4.0
COHERE_RERANK_MODEL=rerank-v3.5
